# Environment Configuration Example
# Copy this to .env and update values as needed

# Database
DATABASE_URL=sqlite:///./stock_data.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/stock_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Environment
ENVIRONMENT=development
# For production: ENVIRONMENT=production

# CORS (for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
